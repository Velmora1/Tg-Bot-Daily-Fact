{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "scr",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["scr/**/*.ts", "scr/keybords"],
  "exclude": ["node_modules", "dist"]
}